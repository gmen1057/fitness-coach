# =============================================================================
# Fitness Coach - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Only configure the AI provider(s) you want to use

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string (required)
DATABASE_URL=postgresql+asyncpg://fitness_user:fitness_pass@localhost/fitness_coach

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Configure ONE OR MORE providers. The first available provider will be used.
# Priority order: ANTHROPIC → OPENAI → OLLAMA

# --- Anthropic Claude (recommended for quality) ---
# Get key at: https://console.anthropic.com/
# Models: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# --- OpenAI GPT (good alternative) ---
# Get key at: https://platform.openai.com/
# Models: gpt-4.1, gpt-5.2, gpt-5.1, gpt-4o-mini
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# --- Ollama (free, self-hosted) ---
# Install from: https://ollama.com/download
# Models: llama3.3, qwen2.5, deepseek-r1 (pull via: ollama pull llama3.3)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3
OLLAMA_MAX_TOKENS=4096
OLLAMA_TEMPERATURE=0.7

# =============================================================================
# RAG (Retrieval-Augmented Generation) - Semantic Memory
# =============================================================================
# RAG enables the AI to remember past workouts, preferences, and insights
# using semantic search (meaning-based, not keyword-based)

# --- RAG Provider ---
# Options: pgvector (PostgreSQL), none (disabled)
FITNESS_RAG_PROVIDER=none

# --- Embedding Provider ---
# Options: ollama (free, local), openai (paid, cloud), none (disabled)
FITNESS_EMBEDDING_PROVIDER=none

# --- Option A: Ollama (FREE, LOCAL) ---
# 1. Install Ollama: https://ollama.ai
# 2. Pull model: ollama pull nomic-embed-text
# 3. Uncomment below:
# FITNESS_EMBEDDING_PROVIDER=ollama
# FITNESS_OLLAMA_BASE_URL=http://localhost:11434
# FITNESS_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Option B: OpenAI (PAID, CLOUD) ---
# Cost: ~$0.02 per 1M tokens (very cheap)
# 1. Get API key: https://platform.openai.com/api-keys
# 2. Uncomment below:
# FITNESS_EMBEDDING_PROVIDER=openai
# FITNESS_OPENAI_API_KEY=sk-your-key-here
# FITNESS_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- PostgreSQL pgvector Extension ---
# Required for RAG. Run once:
# sudo -u postgres psql your_database -c "CREATE EXTENSION IF NOT EXISTS vector;"

# -----------------------------------------------------------------------------
# Optional Features
# -----------------------------------------------------------------------------

# --- Rate Limiting ---
# Protects API from abuse (requests per minute)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# --- CORS ---
# Allowed origins for frontend (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3400

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Default user ID for single-user deployments
# Generate with: python -c "import uuid; print(uuid.uuid4())"
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000000

# Session timeout (seconds)
SESSION_TIMEOUT=3600

# Maximum workout plan weeks
MAX_PLAN_WEEKS=12

# Maximum exercises per day
MAX_EXERCISES_PER_DAY=15

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------

# Enable debug logging
DEBUG=false

# Enable SQL query logging
SQL_ECHO=false

# Enable API documentation
DOCS_ENABLED=true

# -----------------------------------------------------------------------------
# Deployment Examples
# -----------------------------------------------------------------------------

# Example 1: Cloud deployment with Anthropic
# DATABASE_URL=postgresql+asyncpg://user:pass@db.example.com/fitness
# ANTHROPIC_API_KEY=sk-ant-api03-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-5
# CORS_ORIGINS=https://fitness.example.com

# Example 2: Self-hosted with Ollama
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/fitness
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.3
# CORS_ORIGINS=http://localhost:3000

# Example 3: Multi-provider fallback
# ANTHROPIC_API_KEY=sk-ant-api03-xxx
# OPENAI_API_KEY=sk-proj-xxx
# OLLAMA_BASE_URL=http://localhost:11434
# (Will try Anthropic first, then OpenAI, then Ollama)

# -----------------------------------------------------------------------------
# Quick Setup Commands
# -----------------------------------------------------------------------------

# 1. Copy this file
#    cp .env.example .env

# 2. Install dependencies
#    pip install -e ".[cloud]"     # For Anthropic/OpenAI
#    pip install -e ".[local]"     # For Ollama only
#    pip install -e ".[all]"       # For all providers

# 3. Set up database
#    alembic upgrade head

# 4. Run server
#    uvicorn app.main:app --reload

# For Docker deployment, use docker-compose.yml with environment variables
