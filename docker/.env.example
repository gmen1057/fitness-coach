# =============================================================================
# Open Source Fitness Coach - Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Never commit .env to version control (it contains secrets)

# =============================================================================
# Docker Compose Configuration
# =============================================================================
VERSION=latest
INSTALL_EXTRAS=cloud  # Options: base, cloud, ollama, all

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_DB=fitness
POSTGRES_USER=fitness
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_PORT=5432

# =============================================================================
# AI Provider Configuration
# =============================================================================
# Primary AI provider (anthropic, openai, ollama)
FITNESS_AI_PROVIDER=anthropic

# --- Anthropic (Claude) ---
FITNESS_ANTHROPIC_API_KEY=sk-ant-your-api-key-here
FITNESS_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI (GPT) ---
FITNESS_OPENAI_API_KEY=sk-your-api-key-here
FITNESS_OPENAI_MODEL=gpt-4o

# --- Ollama (Local) ---
FITNESS_OLLAMA_BASE_URL=http://ollama:11434
FITNESS_OLLAMA_MODEL=llama3.2

# =============================================================================
# Embedding Provider Configuration
# =============================================================================
# Embedding provider for RAG (openai, ollama, none)
FITNESS_EMBEDDING_PROVIDER=openai
FITNESS_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
FITNESS_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# RAG Provider Configuration
# =============================================================================
# RAG backend (pgvector, sqlite, none)
FITNESS_RAG_PROVIDER=pgvector
FITNESS_RAG_COLLECTION=fitness_memory
FITNESS_EMBEDDING_DIMENSIONS=1536

# =============================================================================
# Application Configuration
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
FITNESS_DEBUG=false
FITNESS_CORS_ORIGINS=["http://localhost:3000"]

# Database URL (auto-generated from POSTGRES_* vars in docker-compose)
# FITNESS_DATABASE_URL=postgresql+asyncpg://fitness:password@postgres:5432/fitness

# Rate limiting
FITNESS_RATE_LIMIT_CHAT=10/minute
FITNESS_RATE_LIMIT_DEFAULT=100/minute

# =============================================================================
# Development Tools (docker-compose.dev.yml)
# =============================================================================
PGADMIN_EMAIL=admin@fitness.local
PGADMIN_PASSWORD=admin
